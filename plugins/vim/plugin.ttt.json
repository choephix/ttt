{
  "name": "vim",
  "displayName": "Vim Mode",
  "description": "Vim compatibility layer: modal editing, motions, operators, text objects, registers, marks and macros.",
  "version": "0.1.0",
  "author": "ttt",
  "entry": "init.lua",
  "api": 2,
  "permissions": {
    "keybindings": true,
    "editor.read": true,
    "editor.write": true,
    "commands": true,
    "fs.write": true,
    "settings": true,
    "settings_keys": ["vim.enabled", "vim.clipboard"]
  }
}
