{
  "version": 1,
  "theme": "default-dark",
  "editor": {
    "tabSize": 4,
    "insertSpaces": true,
    "wordWrap": false,
    "lineNumbers": true,
    "formatOnSave": false,
    "insertFinalNewline": true,
    "trimTrailingWhitespace": false,
    "focusOnOpen": false,
    "gutterStyle": "compact",
    "borderStyle": "default",
    "bracketPairColorization": false
  },
  "search": {
    "debounce": 350
  },
  "explorer": {
    "showHidden": true,
    "showGitIgnored": true
  },
  "terminal": {
    "scrollback": 1000
  },
  "lsp": {
    "saveOnRename": false,
    "hoverDelay": 500
  },
  "autocomplete": {
    "enabled": true,
    "autoSuggest": true,
    "debounce": 150,
    "signatureHelp": true
  },
  "markdown": {
    "wrapWidth": 80
  }
}
